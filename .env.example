# ─── Database (required) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:@localhost:5432/indigo

# ─── Auth (required) ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long

# ─── Application (required) ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Indigo
NODE_ENV=development
PORT=3000

# ─── Admin ────────────────────────────────────────────────────────────────────
# Set to true to allow self-registration at /dashboard/register
NEXT_PUBLIC_ADMIN_REGISTRATION_ENABLED=false

# ─── Organizations ───────────────────────────────────────────────────────────
# Show org UI (OrgSwitcher, org management). Default: true.
# Personal org is always auto-created for billing/tokens, even when false.
# Set to false for B2C apps that don't need multi-org.
NEXT_PUBLIC_ORGANIZATIONS_VISIBLE=true

# ─── Server ──────────────────────────────────────────────────────────────────
# SERVER_ROLE: all | frontend | api | worker
SERVER_ROLE=all

# ─── Redis (optional — enables BullMQ email queue) ──────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# ─── Email / SMTP (optional) ────────────────────────────────────────────────
# Without SMTP config, emails are logged to console in development
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=noreply@example.com

# ─── Social Login (optional) ────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_DISCORD_CLIENT_ID=

# ─── Storage ────────────────────────────────────────────────────────────────
# filesystem (default) or s3
STORAGE_BACKEND=filesystem

# S3-compatible storage (required when STORAGE_BACKEND=s3)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_BUCKET=indigo-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# NEXT_PUBLIC_CDN_URL=

# ─── Stripe (optional — billing disabled without secret key) ──────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe price IDs — create in Stripe dashboard, one per plan × interval
# STRIPE_PRICE_STARTER_MONTHLY=price_...
# STRIPE_PRICE_STARTER_YEARLY=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...
# STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
# STRIPE_PRICE_ENTERPRISE_YEARLY=price_...

# ─── NOWPayments (optional — crypto payments disabled without API key) ──────
# NOWPAYMENTS_API_KEY=
# NOWPAYMENTS_IPN_SECRET=
# NOWPAYMENTS_SANDBOX=true

# ─── DeepL Translation (optional) ──────────────────────────────────────────
# DEEPL_API_KEY=
# DEEPL_API_FREE=true

# ─── Encryption (auto-generated by `bun run init`) ────────────────────────
# 64-char hex key for AES-256-GCM encryption of stored credentials
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=

# ─── ElevenLabs (optional — voice calls disabled without API key) ─────────
# ELEVENLABS_API_KEY=
# ELEVENLABS_DEFAULT_VOICE_ID=

# ─── Mock AI (set to true for local dev without API keys) ─────────────────
# MOCK_AI=true

# ─── WebSocket ──────────────────────────────────────────────────────────────
# WS_ENABLED=true

# ─── Sentry (optional — error tracking disabled without DSN) ──────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project

# ─── Docker Compose (used by docker-compose.prod.yml) ─────────────────────
# Generate with: openssl rand -hex 16
# POSTGRES_PASSWORD=change-me
