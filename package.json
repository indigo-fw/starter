{
  "name": "indigo",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "bun run server.ts",
    "dev:next": "next dev --turbopack",
    "build": "next build",
    "start": "NODE_ENV=production bun run server.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio",
    "db:search-triggers": "bun -e \"import{applySearchTriggers}from'./src/scripts/apply-search-triggers';applySearchTriggers()\"",
    "init": "bun run src/scripts/init.ts",
    "promote": "bun run src/scripts/promote.ts",
    "change-password": "bun run src/scripts/change-password.ts",
    "content:sync": "bun run src/scripts/content-sync.ts",
    "i18n": "bun scripts/i18n/generate-po-files.js && bun scripts/i18n/po-to-json.mjs",
    "i18n:translate": "bun scripts/i18n/generate-po-files.js && bun scripts/i18n/translate-po.mjs && bun scripts/i18n/po-to-json.mjs",
    "i18n:watch": "bun scripts/i18n/po-to-json.mjs watch",
    "test": "vitest",
    "indigo": "bun run scripts/indigo.ts",
    "indigo:sync": "bun run scripts/sync-modules.ts",
    "release": "git push && bun run indigo push --all",
    "core:push": "git subtree push --prefix=src/core git@github.com:indigo-fw/core.git main",
    "core:pull": "git subtree pull --prefix=src/core git@github.com:indigo-fw/core.git main --squash",
    "prepare": "husky"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.1.21",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/dom": "^1.7.6",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.95.2",
    "@tiptap/extension-code-block-lowlight": "^3.21.0",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-table": "^3.22.1",
    "@tiptap/extension-table-cell": "^3.22.1",
    "@tiptap/extension-table-header": "^3.22.1",
    "@tiptap/extension-table-row": "^3.22.1",
    "@tiptap/extension-text-align": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@tiptap/suggestion": "^3.22.1",
    "@trpc/client": "^11.13.0",
    "@trpc/next": "^11.13.0",
    "@trpc/react-query": "^11.13.0",
    "@trpc/server": "^11.13.0",
    "better-auth": "^1.5.6",
    "bullmq": "^5.71.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "next": "16.2.1",
    "next-intl": "^4.9.0",
    "nodemailer": "^8.0.4",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^21.0.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "chokidar": "^5.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "lint-staged": {
    "*.{tsx,jsx,ts,css}": "node scripts/fix-tailwind-classes.mjs"
  }
}
